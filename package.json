{
  "name": "pick-components",
  "version": "1.0.6",
  "description": "A tiny lifecycle-focused framework for building reactive web components",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "import": "./dist/bootstrap.js",
      "default": "./dist/bootstrap.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "pick-components-copilot": "scripts/export-copilot-skill.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "!dist/browser/**",
    ".github/skills/setup-pick-components/**",
    "scripts/export-copilot-skill.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "build:lib": "npm run clean:dist && tsc -p tsconfig.json",
    "build:browser": "rollup -c rollup.config.mjs",
    "build:prod": "npm run build:lib && npm run build:browser",
    "build:release": "npm run build:prod && node scripts/prepare-release-artifacts.mjs",
    "build:examples": "node scripts/build-examples.mjs",
    "build": "npm run build:prod && npm run build:examples",
    "copilot:export-skill": "node scripts/export-copilot-skill.mjs",
    "pretest": "node scripts/guardrails.mjs && node scripts/check-no-browser-in-node-tests.mjs",
    "serve:dev": "node scripts/serve-examples.mjs",
    "serve:dist": "node scripts/serve-dist.mjs",
    "test": "npm run test:unit && npm run test:integration && npm run test:browser",
    "test:unit": "cross-env SKIP_WEBSERVER=1 playwright test --project=unit",
    "test:unit:node": "npm run test:unit",
    "test:integration": "cross-env SKIP_WEBSERVER=1 playwright test --project=integration",
    "test:integration:node": "npm run test:integration",
    "pretest:browser": "npm run build:prod",
    "test:browser": "cross-env SKIP_WEBSERVER=1 playwright test --project=browser",
    "test:coverage": "node scripts/run-coverage.mjs",
    "test:playground": "playwright test --project=playground",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "keywords": [
    "typescript",
    "components",
    "reactive",
    "lifecycle",
    "mvvm",
    "vanilla",
    "web-components"
  ],
  "author": "janmbaco",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@picocss/pico": "^2.1.1",
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.19.26",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "codemirror": "^6.0.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.2.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.57.0",
    "prettier": "^3.3.3",
    "rollup": "^4.53.3",
    "terser": "^5.44.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pick-components/pick-components.git"
  }
}
